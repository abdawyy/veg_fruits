APP_NAME="AL-DAWY"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=aldawy
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=aldawy_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

ALDAWY_INVOICE_SENDER_NAME="abdelrahman mohamed"
ALDAWY_DECIMAL_SCALE=4

# SMS: log (dev) | http (production gateway)
ALDAWY_SMS_DRIVER=log
ALDAWY_SMS_HTTP_URL=
ALDAWY_SMS_HTTP_METHOD=POST
ALDAWY_SMS_HTTP_PHONE_KEY=to
ALDAWY_SMS_HTTP_MESSAGE_KEY=message
ALDAWY_SMS_HTTP_API_KEY=
ALDAWY_SMS_HTTP_API_KEY_HEADER=Authorization

# Set true to show "Pay online" at checkout (pending staff confirmation)
ALDAWY_ONLINE_PAYMENT_ENABLED=false

# Require verified email before /my account panel
ALDAWY_REQUIRE_EMAIL_VERIFICATION=false

# Phone OTP login (storefront /login/phone)
ALDAWY_PHONE_OTP_ENABLED=true
ALDAWY_OTP_DRIVER=log
ALDAWY_OTP_TTL_MINUTES=10

ALDAWY_INVOICE_SIGNED_DAYS=14

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Optional storefront tags (leave empty to disable)
ANALYTICS_GA4_MEASUREMENT_ID=
ANALYTICS_META_PIXEL_ID=
